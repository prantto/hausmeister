# Hausmeister backend
DATABASE_URL=postgresql://hausmeister:hausmeister@localhost:5432/hausmeister

# LLM (Gemini for both the sync RAG loop and gradbot's live agent).
GEMINI_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash
# LLM_API_KEY defaults to GEMINI_API_KEY in compose.
# LLM_API_KEY=

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
ADMIN_PASSWORD=change-me

# Gradium voice (STT + TTS) — required for /transcribe, /tts, and the
# live /voice/stream loop.
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=
GRADIUM_STT_MODEL=default

# Live voice transport on the WebSocket: 1 = raw PCM, 0 = OggOpus.
USE_PCM=1

# Optional — enables POST /ask-the-news (Tavily news search)
TAVILY_API_KEY=
