# Hausmeister — root env, consumed by docker-compose.yml
# Copy to .env and fill in. Anything left blank uses the compose default
# (see docker-compose.yml `${VAR:-default}` fallbacks).

# --- LLM (required) ---
# Used both by the synchronous /ask + /tagesbericht (google-genai) and by
# the live /talk loop (gradbot, via Gemini's OpenAI-compatible endpoint).
GEMINI_API_KEY=

# Override only if you want a non-default Gemini route or a different
# OpenAI-compatible LLM (Groq, OpenRouter, etc.). LLM_API_KEY defaults
# to GEMINI_API_KEY.
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-2.5-flash
# LLM_API_KEY=

# --- Admin kill-switch ---
# Header X-Admin-Password on /admin/* must match this.
ADMIN_PASSWORD=change-me

# --- Voice in + out (Gradium, via gradbot) ---
# Required for /transcribe, /tts, and the /voice/stream live loop.
GRADIUM_API_KEY=
# Default voice picked at startup if the user hasn't chosen one in the UI.
# Leave empty to force the picker; otherwise pick a uid from /api/voices.
GRADIUM_VOICE_ID=

# Audio transport on the live /talk WebSocket. 1 = raw PCM (simpler),
# 0 = OggOpus (smaller bytes, slightly more browser plumbing). Both are
# supported end-to-end by gradbot's bundled audio worklet.
# USE_PCM=1

# --- Optional: cross-reference with Tavily news (/ask-the-news) ---
# Endpoint returns 503 when this is unset.
TAVILY_API_KEY=
